{
  "info": {
    "name": "CampFix - Change Password Tests",
    "_postman_id": "campfix-change-password-tests",
    "description": "Tests for PUT /profile/password endpoint. Covers the updated password validation rules: min 8 chars, uppercase, lowercase, number, special char, and common password blocklist.\n\n**Setup before running:**\n1. Log in via browser at http://127.0.0.1:8000\n2. Open DevTools → Application → Cookies → copy the `laravel_session` value into the `session_cookie` variable\n3. Open DevTools → Network → any POST request → copy the `_token` value into `csrf_token`\n4. Set `current_password` to your actual current password",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "csrf_token", "value": "PASTE_CSRF_TOKEN_HERE", "type": "string" },
    { "key": "session_cookie", "value": "PASTE_SESSION_COOKIE_HERE", "type": "string" },
    { "key": "current_password", "value": "PASTE_CURRENT_PASSWORD_HERE", "type": "string" }
  ],
  "item": [
    {
      "name": "✅ Valid Password - Should Succeed",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 302 (success/redirect)', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
              "});",
              "",
              "pm.test('No validation errors returned', () => {",
              "    if (pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) {",
              "        const j = pm.response.json();",
              "        pm.expect(j.errors).to.not.exist;",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
          { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{current_password}}\",\n  \"new_password\": \"NewPass@123\",\n  \"new_password_confirmation\": \"NewPass@123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile", "password"] },
        "description": "Valid password: has uppercase (N, P), lowercase (ew, ass), number (1, 2, 3), special char (@). Should succeed."
      }
    },
    {
      "name": "❌ Missing Uppercase - Should Fail (422)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 422 - validation error', () => {",
              "    pm.expect(pm.response.code).to.eql(422);",
              "});",
              "",
              "pm.test('new_password error present', () => {",
              "    const j = pm.response.json();",
              "    pm.expect(j.errors).to.have.property('new_password');",
              "});",
              "",
              "pm.test('Regex error message returned', () => {",
              "    const j = pm.response.json();",
              "    const msg = j.errors.new_password.join(' ');",
              "    pm.expect(msg).to.include('uppercase');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
          { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{current_password}}\",\n  \"new_password\": \"newpass@123\",\n  \"new_password_confirmation\": \"newpass@123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile", "password"] },
        "description": "No uppercase letters. Should fail regex validation."
      }
    },
    {
