    {
      "name": "❌ Passwords Don't Match - Should Fail (422)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 422 - validation error', () => {",
              "    pm.expect(pm.response.code).to.eql(422);",
              "});",
              "",
              "pm.test('new_password confirmation error', () => {",
              "    const j = pm.response.json();",
              "    pm.expect(j.errors).to.have.property('new_password');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
          { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"current_password\": \"{{current_password}}\",\n  \"new_password\": \"NewPass@123\",\n  \"new_password_confirmation\": \"DifferentPass@456\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile", "password"] },
        "description": "new_password and new_password_confirmation don't match. Should fail 'confirmed' rule."
      }
    },
    {
      "name": "❌ Wrong Current Password - Should Fail (422)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 422 - wrong current password', () => {",
              "    pm.expect(pm.response.code).to.eql(422);",
              "});",
              "",
              "pm.test('current_password error present', () => {",
              "    const j = pm.response.json();",
              "    pm.expect(j.errors).to.have.property('current_password');",
              "});",
              "",
              "pm.test('Error says password is incorrect', () => {",
