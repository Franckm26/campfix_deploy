{
  "info": {
    "name": "CampFix - Full Test Suite",
    "_postman_id": "campfix-full-suite",
    "description": "Complete end-to-end test collection for CampFix. Covers Auth (login, OTP, JWT), Profile, Settings, Concerns, Reports, Events, and Admin flows.\n\n## Setup\n1. Set `base_url` to your app URL (default: http://127.0.0.1:8000)\n2. For web routes: log in via browser, copy `laravel_session` cookie → `session_cookie`, and copy `_token` from any form → `csrf_token`\n3. For API routes: run the 'API Login' request first — it auto-saves `jwt_token`\n4. Set `test_email`, `test_password`, `admin_email`, `admin_password` to real credentials\n\n## Run Order\nFolders are ordered: Auth → API Auth → Profile → Settings → Concerns → Reports → Events → Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "csrf_token",      "value": "PASTE_CSRF_TOKEN_HERE",  "type": "string" },
    { "key": "session_cookie",  "value": "PASTE_SESSION_COOKIE",   "type": "string" },
    { "key": "jwt_token",       "value": "",                        "type": "string" },
    { "key": "test_email",      "value": "student@novaliches.sti.edu.ph", "type": "string" },
    { "key": "test_password",   "value": "YourPassword@123",        "type": "string" },
    { "key": "admin_email",     "value": "admin@novaliches.sti.edu.ph",   "type": "string" },
    { "key": "admin_password",  "value": "AdminPass@123",            "type": "string" },
    { "key": "concern_id",      "value": "1",                        "type": "string" },
    { "key": "report_id",       "value": "1",                        "type": "string" },
    { "key": "event_id",        "value": "1",                        "type": "string" },
    { "key": "category_id",     "value": "1",                        "type": "string" },
    { "key": "user_id",         "value": "1",                        "type": "string" }
  ],
  "item": [

    {
      "name": "1. Web Auth",
      "item": [
        {
          "name": "Login (Web - valid credentials)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 or 302', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));",
            "pm.test('No error in response', () => { if (pm.response.headers.get('Content-Type') && pm.response.headers.get('Content-Type').includes('application/json')) { pm.expect(pm.response.json().error).to.not.exist; } });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "_token", "value": "{{csrf_token}}" },
              { "key": "email", "value": "{{test_email}}" },
              { "key": "password", "value": "{{test_password}}" }
            ]},
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Web login. Redirects to OTP choice on success. Rate limited to 5/min."
          }
        },
        {
          "name": "Login - Invalid Domain (should fail)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 or 302 (redirect back with error)', () => pm.expect(pm.response.code).to.be.oneOf([200, 302, 422]));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "_token", "value": "{{csrf_token}}" },
              { "key": "email", "value": "user@gmail.com" },
              { "key": "password", "value": "SomePass@1" }
            ]},
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Non-STI email should be rejected."
          }
        },
        {
          "name": "Logout (Web)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 or 302', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "_token", "value": "{{csrf_token}}" }
            ]},
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        }
      ]
    },

    {
      "name": "2. API Auth (JWT)",
      "item": [
        {
          "name": "Health Check",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status is healthy', () => pm.expect(pm.response.json().status).to.eql('healthy'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api","health"] }
          }
        },
        {
          "name": "API Register",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Token returned', () => { const j = pm.response.json(); pm.expect(j.token).to.be.a('string'); pm.environment.set('jwt_token', j.token); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"teststudent@novaliches.sti.edu.ph\",\n  \"password\": \"TestPass@123\",\n  \"password_confirmation\": \"TestPass@123\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "description": "Email must be @novaliches.sti.edu.ph. Password: min 8, uppercase, lowercase, number, special char."
          }
        },
        {
          "name": "API Register - Weak Password (422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Password error present', () => pm.expect(pm.response.json().errors).to.have.property('password'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"weak@novaliches.sti.edu.ph\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "API Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('JWT token saved', () => { const j = pm.response.json(); pm.expect(j.token).to.be.a('string'); pm.expect(j.token_type).to.eql('bearer'); pm.collectionVariables.set('jwt_token', j.token); });",
            "pm.test('User info returned', () => { const j = pm.response.json(); pm.expect(j.user).to.have.all.keys('id','name','email','role'); });"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "description": "Rate limited to 5 attempts/min. Token auto-saved to jwt_token variable."
          }
        },
        {
          "name": "API Login - Wrong Password (401)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"WrongPass@999\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "API Get Current User",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('User object valid', () => { const j = pm.response.json(); pm.expect(j.user).to.have.all.keys('id','name','email','role'); });"
          ]}}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]},
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/user", "host": ["{{base_url}}"], "path": ["api","auth","user"] }
          }
        },
        {
          "name": "API Refresh Token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('New token saved', () => { const j = pm.response.json(); pm.expect(j.token).to.be.a('string'); pm.collectionVariables.set('jwt_token', j.token); });"
          ]}}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]},
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/refresh", "host": ["{{base_url}}"], "path": ["api","auth","refresh"] }
          }
        },
        {
          "name": "API Logout",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Logged out message', () => pm.expect(pm.response.json().message).to.include('Logged out'));"
          ]}}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]},
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },

    {
      "name": "3. Profile (Web - requires session)",
      "item": [
        {
          "name": "View Profile",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/html" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Update Profile Info",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 or 302', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"{{test_email}}\",\n  \"phone\": \"09123456789\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] },
            "description": "Phone must match 09XXXXXXXXX format."
          }
        },
        {
          "name": "Update Profile - Invalid Phone (422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Phone error present', () => pm.expect(pm.response.json().errors).to.have.property('phone'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"{{test_email}}\",\n  \"phone\": \"12345\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Change Password - Valid",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 or 302', () => pm.expect(pm.response.code).to.be.oneOf([200, 302]));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"{{test_password}}\",\n  \"new_password\": \"NewPass@456\",\n  \"new_password_confirmation\": \"NewPass@456\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile","password"] }
          }
        },
        {
          "name": "Change Password - Common Password (422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Too common error', () => { const msg = pm.response.json().errors.new_password.join(' '); pm.expect(msg).to.include('too common'); });"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"{{test_password}}\",\n  \"new_password\": \"admin123\",\n  \"new_password_confirmation\": \"admin123\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile","password"] }
          }
        },
        {
          "name": "Change Password - Wrong Current Password (422)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('current_password error', () => pm.expect(pm.response.json().errors).to.have.property('current_password'));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-CSRF-TOKEN", "value": "{{csrf_token}}" },
              { "key": "Cookie", "value": "laravel_session={{session_cookie}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"WrongPass@999\",\n  \"new_password\": \"NewPass@456\",\n  \"new_password_confirmation\": \"NewPass@456\"\n}", "options": { "raw": { "language": "json" }}},
            "url": { "raw": "{{base_url}}/profile/password", "host": ["{{base_url}}"], "path": ["profile","password"] }
          }
        }
      ]
    },

